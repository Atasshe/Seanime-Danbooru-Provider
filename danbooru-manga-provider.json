{
    "id": "danbooru-manga-provider",
    "name": "Danbooru",
    "description": "Provedor de imagens do Danbooru para o leitor de Mangá",
    "manifestURI": "https://raw.githubusercontent.com/SEU_USUARIO/SEU_REPOSITORIO/main/danbooru-manga-provider.json",
    "version": "1.0.0",
    "author": "Developer",
    "type": "manga-provider",
    "language": "typescript",
    "lang": "multi",
    "payloadURI": "https://raw.githubusercontent.com/atasshe/Seanime-Danbooru-Provider/main/provider.ts",
    "userConfig": {
        "requiresConfig": false,
        "version": 1,
        "fields": [
            {
                "name": "danbooru_username",
                "label": "Danbooru Username",
                "type": "text",
                "default": ""
            },
            {
                "name": "danbooru_api_key",
                "label": "Danbooru API Key",
                "type": "text",
                "default": ""
            }
        ]
    }
}
